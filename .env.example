# zigporter configuration
#
# When installed as a global tool (uv tool install zigporter), place this file at:
#   ~/.config/zigporter/.env
# Or run `zigporter setup` to create it interactively.
#
# When running from source with `uv run`, a .env in the current directory is also
# picked up automatically (takes precedence over the global config).
# Environment variables always override file values.
#
HA_URL=https://your-ha-instance.local
HA_TOKEN=your_long_lived_access_token_here
# Optional: set to false if using a self-signed certificate
HA_VERIFY_SSL=true
# Zigbee2MQTT add-on ingress URL (found in browser when opening Z2M in HA)
Z2M_URL=https://your-ha-instance.local/45df7312_zigbee2mqtt
# Optional: only needed if your Z2M uses a non-default MQTT base topic (default: zigbee2mqtt)
# Z2M_MQTT_TOPIC=zigbee2mqtt
